#!/bin/bash
# antidistractor-ctl — Guardian control helper
# 以 root 身份运行（sudoers NOPASSWD 配置），连接 Unix socket 发送单条 JSON 命令。
#
# 支持的命令：
#   {"cmd":"status"}
#   {"cmd":"block","domains":["bilibili.com"]}
#   {"cmd":"unblock","domains":["bilibili.com"]}
#   {"cmd":"sync","blocked_domains":["bilibili.com"],"blocked_apps":["steam"]}
#   {"cmd":"block_apps","apps":["steam"]}
#   {"cmd":"unblock_apps","apps":["steam"]}
#   {"cmd":"block_app","names":["WeChat"],"paths":[]}
#   {"cmd":"unblock_app","names":["WeChat"],"paths":[]}
#   {"cmd":"focus_mode","enabled":true,"domains":["tiktok.com"]}
#   {"cmd":"freeze_app","names":["Bilibili"]}
#   {"cmd":"thaw_app","names":["Bilibili"]}
#
# 用法：antidistractor-ctl '{"cmd":"sync","blocked_domains":["bilibili.com"],"blocked_apps":[]}'

set -euo pipefail

SOCKET=/var/run/antidistractor.sock

if [ ! -S "$SOCKET" ]; then
  echo '{"ok":false,"error":"socket not found — is antidistractor running?"}' >&1
  exit 1
fi

if [ $# -ne 1 ]; then
  echo '{"ok":false,"error":"usage: antidistractor-ctl <json>"}' >&1
  exit 1
fi

# socat 发送命令并读回响应（超时 3 秒）
echo "$1" | socat -t3 - UNIX-CONNECT:"$SOCKET"
